generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  deviceName  String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions PushSubscription[]
  watchlist     Watchlist[]
  settings      UserSignalSettings?
  signals       SignalEvent[]
  alerts        AlertDelivery[]
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  platform  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts  AlertDelivery[]
}

model Watchlist {
  id        String   @id @default(uuid())
  userId    String
  symbol    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

model UserSignalSettings {
  id                   String   @id @default(uuid())
  userId               String   @unique
  universeMode         String   @default("TOP_50")
  symbols              String   @default("[]")
  excludedSymbols      String   @default("[]")
  timeframes           String   @default("[\"1h\",\"4h\"]")
  indicators           String   @default("[\"UT\",\"VRT\",\"SUPER\"]")
  minMatch             Int      @default(2)
  mode                 String   @default("SWING")
  minConfidence        Int      @default(78)
  minSeq               Int      @default(72)
  minRR                Float    @default(1.8)
  maxLateRisk          Int      @default(35)
  minConfirmations     Int      @default(3)
  onlyClosedCandle     Boolean  @default(true)
  onlyAPlus            Boolean  @default(false)
  allowPrepAlerts      Boolean  @default(true)
  allowPullbackAlerts  Boolean  @default(true)
  allowLateWarnings    Boolean  @default(true)
  allowSleepingAlerts  Boolean  @default(true)
  cooldownMinutes      Int      @default(30)
  useMarketRegimeFilter Boolean @default(true)
  useDerivativesFilter  Boolean @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SignalEvent {
  id             String   @id @default(uuid())
  userId         String?
  symbol         String
  timeframe      String
  signal         String
  direction      String
  confidence     Int
  quality        String
  seqScore       Int
  amcScore       Int
  lateRisk       Int
  rr             Float
  entryLow       Float
  entryHigh      Float
  stopLoss       Float
  tp1            Float
  tp2            Float
  tp3            Float
  marketRegime   String
  reasons        String   @default("[]")
  candleCloseTime DateTime
  duplicateKey   String   @unique
  createdAt      DateTime @default(now())

  user    User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  alerts  AlertDelivery[]
  outcome SignalOutcome?
  snapshot IndicatorSnapshot?
}

model AlertDelivery {
  id                 String   @id @default(uuid())
  signalEventId      String
  userId             String
  pushSubscriptionId String?
  status             String   @default("SENT")
  error              String?
  createdAt          DateTime @default(now())

  signalEvent      SignalEvent        @relation(fields: [signalEventId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushSubscription PushSubscription? @relation(fields: [pushSubscriptionId], references: [id], onDelete: SetNull)
}

model SignalOutcome {
  id                     String   @id @default(uuid())
  signalEventId          String   @unique
  symbol                 String
  timeframe              String
  direction              String
  signal                 String
  entryLow               Float
  entryHigh              Float
  stopLoss               Float
  tp1                    Float
  tp2                    Float
  tp3                    Float
  candleCloseTime        DateTime
  evaluationWindowHours  Int      @default(72)
  status                 String   @default("PENDING") // PENDING, ENTRY_TRIGGERED, TP1_HIT, TP2_HIT, TP3_HIT, STOP_HIT, EXPIRED, INVALIDATED, MISSED
  entryTriggeredAt       DateTime?
  tp1HitAt               DateTime?
  tp2HitAt               DateTime?
  tp3HitAt               DateTime?
  stopHitAt              DateTime?
  expiredAt              DateTime?
  mfePercent             Float    @default(0) // Max Favorable Excursion %
  maePercent             Float    @default(0) // Max Adverse Excursion %
  mfeR                   Float    @default(0)
  maeR                   Float    @default(0)
  finalR                 Float    @default(0)
  barsToEntry            Int      @default(0)
  barsToTp1              Int      @default(0)
  barsToStop             Int      @default(0)
  returnAfter3Bars       Float    @default(0)
  returnAfter5Bars       Float    @default(0)
  returnAfter10Bars      Float    @default(0)
  returnAfter24h         Float    @default(0)
  returnAfter72h         Float    @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  signalEvent SignalEvent @relation(fields: [signalEventId], references: [id], onDelete: Cascade)
}

model IndicatorSnapshot {
  id              String   @id @default(uuid())
  signalEventId   String   @unique
  symbol          String
  timeframe       String
  direction       String
  utDirection     Int      @default(0)
  vrtDirection    Int      @default(0)
  vrtRegime       String   @default("")
  stDirection     Int      @default(0)
  emaTrend        Int      @default(0)
  amcScore        Float    @default(50)
  seqScore        Int      @default(0)
  lateRisk        Int      @default(0)
  rr              Float    @default(0)
  marketRegime    String   @default("MIXED")
  activeComboKey  String   @default("")
  createdAt       DateTime @default(now())

  signalEvent SignalEvent @relation(fields: [signalEventId], references: [id], onDelete: Cascade)
}

model MarketSnapshot {
  id             String   @id @default(uuid())
  btcTrend       String
  ethTrend       String
  btcDom         Float?
  usdtDom        Float?
  othersTrend    String?
  fearGreed      Int?
  marketRegime   String
  regimeScore    Float
  createdAt      DateTime @default(now())
}

model CoinMetadata {
  id              String   @id @default(uuid())
  symbol          String   @unique
  baseAsset       String
  name            String?
  marketCapRank   Int?
  quoteVolume     Float    @default(0)
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}
