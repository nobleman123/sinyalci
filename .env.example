# ── DATABASE ──────────────────────────────────────────
# Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Railway:  postgresql://postgres:[PASSWORD]@[HOST]:5432/railway
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexus

# ── REDIS ─────────────────────────────────────────────
# Upstash: redis://default:[TOKEN]@[HOST]:[PORT]
# Railway: redis://default:[PASSWORD]@[HOST]:[PORT]
REDIS_URL=redis://localhost:6379

# ── SERVER ────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── FRONTEND ──────────────────────────────────────────
# CORS whitelist — change to your deployed frontend URL
FRONTEND_ORIGIN=http://localhost:3000

# ── BINANCE ───────────────────────────────────────────
BINANCE_FAPI_BASE=https://fapi.binance.com/fapi/v1
BINANCE_FAPI_DATA=https://fapi.binance.com/futures/data

# ── EXTERNAL APIs ─────────────────────────────────────
COINGECKO_BASE=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
FEAR_GREED_URL=https://api.alternative.me/fng/

# ── COINGLASS (opsiyonel) ─────────────────────────────
COINGLASS_API_KEY=
COINGLASS_BASE=https://open-api-v4.coinglass.com

# ── WEB PUSH VAPID ────────────────────────────────────
# Üretmek için: cd backend && npm run vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@nexus-signal.app
